//@version=6
indicator("GexLab Futures Levels", overlay=true, max_boxes_count=100, max_lines_count=100, max_labels_count=100)

// Paste the "pine" value from http://localhost:8000/api/metrics/bridge.
// Format per section (22 values):
// d0cw,d0pw,d0vt,d1cw,d1pw,d1vt,gp1,gp2,gp3,gp4,gp5,gn1,gn2,gn3,gn4,gn5,dc1,dc2,dc3,dp1,dp2,dp3
pine_data = input.text_area("", title="Futures Levels", group="Data")

show_0dte = input.bool(true, "0DTE", group="Levels")
show_1dte = input.bool(true, "1DTE", group="Levels")
gamma_pos_count = input.int(5, "Γ Positive Levels (0-5)", minval=0, maxval=5, group="Levels")
gamma_neg_count = input.int(5, "Γ Negative Levels (0-5)", minval=0, maxval=5, group="Levels")
show_delta = input.bool(true, "Δ Levels", group="Levels")
delta_count = input.int(3, "Δ Levels Per Side (0-3)", minval=0, maxval=3, group="Levels")
show_boxes = input.bool(true, "Boxes", group="Style")
box_half_override = input.float(0.0, "Box Half-Width, Points (0 = Auto)", minval=0.0, step=0.25, group="Style")
merge_override = input.float(0.0, "Merge Distance, Points (0 = Auto)", minval=0.0, step=0.25, group="Style")

symbol_text = str.upper(syminfo.ticker)
is_nq = str.contains(symbol_text, "NQ")
section_idx = is_nq ? 1 : 0
auto_half_points = is_nq ? 20.0 : 5.0
box_half_points = box_half_override > 0 ? box_half_override : auto_half_points
merge_points = merge_override > 0 ? merge_override : box_half_points * 2.0

f_parse(idx) =>
    sections = str.split(pine_data, "|")
    section = array.size(sections) > section_idx ? array.get(sections, section_idx) : ""
    fields = str.split(section, ",")
    raw = array.size(fields) > idx ? str.tonumber(str.trim(array.get(fields, idx))) : float(na)
    raw == 0.0 ? float(na) : raw

tick(v) => na(v) ? float(na) : math.round(v * 4.0) / 4.0

d0cw = show_0dte ? tick(f_parse(0)) : float(na)
d0pw = show_0dte ? tick(f_parse(1)) : float(na)
d0vt = show_0dte ? tick(f_parse(2)) : float(na)
d1cw = show_1dte ? tick(f_parse(3)) : float(na)
d1pw = show_1dte ? tick(f_parse(4)) : float(na)
d1vt = show_1dte ? tick(f_parse(5)) : float(na)
gp1 = gamma_pos_count >= 1 ? tick(f_parse(6)) : float(na)
gp2 = gamma_pos_count >= 2 ? tick(f_parse(7)) : float(na)
gp3 = gamma_pos_count >= 3 ? tick(f_parse(8)) : float(na)
gp4 = gamma_pos_count >= 4 ? tick(f_parse(9)) : float(na)
gp5 = gamma_pos_count >= 5 ? tick(f_parse(10)) : float(na)
gn1 = gamma_neg_count >= 1 ? tick(f_parse(11)) : float(na)
gn2 = gamma_neg_count >= 2 ? tick(f_parse(12)) : float(na)
gn3 = gamma_neg_count >= 3 ? tick(f_parse(13)) : float(na)
gn4 = gamma_neg_count >= 4 ? tick(f_parse(14)) : float(na)
gn5 = gamma_neg_count >= 5 ? tick(f_parse(15)) : float(na)
dc1 = show_delta and delta_count >= 1 ? tick(f_parse(16)) : float(na)
dc2 = show_delta and delta_count >= 2 ? tick(f_parse(17)) : float(na)
dc3 = show_delta and delta_count >= 3 ? tick(f_parse(18)) : float(na)
dp1 = show_delta and delta_count >= 1 ? tick(f_parse(19)) : float(na)
dp2 = show_delta and delta_count >= 2 ? tick(f_parse(20)) : float(na)
dp3 = show_delta and delta_count >= 3 ? tick(f_parse(21)) : float(na)

var float[] zone_anchor = array.new_float()
var float[] zone_min = array.new_float()
var float[] zone_max = array.new_float()
var string[] zone_text = array.new_string()
var color[] zone_color = array.new_color()
var color[] zone_text_color = array.new_color()
var int[] zone_count = array.new_int()
var box[] zone_boxes = array.new_box()
var line[] zone_lines = array.new_line()
var label[] zone_labels = array.new_label()

f_clear_drawings() =>
    while array.size(zone_boxes) > 0
        box.delete(array.pop(zone_boxes))
    while array.size(zone_lines) > 0
        line.delete(array.pop(zone_lines))
    while array.size(zone_labels) > 0
        label.delete(array.pop(zone_labels))

f_clear_zones() =>
    array.clear(zone_anchor)
    array.clear(zone_min)
    array.clear(zone_max)
    array.clear(zone_text)
    array.clear(zone_color)
    array.clear(zone_text_color)
    array.clear(zone_count)

f_add_zone(price, txt, col) =>
    if not na(price)
        merged = false
        zone_size = array.size(zone_anchor)
        if zone_size > 0
            for i = 0 to zone_size - 1
                zone_lo = array.get(zone_min, i)
                zone_hi = array.get(zone_max, i)
                if price >= zone_lo - merge_points and price <= zone_hi + merge_points
                    old_count = array.get(zone_count, i)
                    new_count = old_count + 1
                    array.set(zone_min, i, math.min(array.get(zone_min, i), price))
                    array.set(zone_max, i, math.max(array.get(zone_max, i), price))
                    existing = array.get(zone_text, i)
                    array.set(zone_text, i, str.contains(existing, txt) ? existing : existing + " / " + txt)
                    array.set(zone_color, i, #f59e0b)
                    array.set(zone_count, i, new_count)
                    merged := true
                    break
        if not merged
            array.push(zone_anchor, price)
            array.push(zone_min, price)
            array.push(zone_max, price)
            array.push(zone_text, txt)
            array.push(zone_color, col)
            array.push(zone_text_color, col)
            array.push(zone_count, 1)

f_draw_zones() =>
    zone_size = array.size(zone_anchor)
    if zone_size > 0
        for i = 0 to zone_size - 1
            lo = tick(array.get(zone_min, i) - box_half_points)
            hi = tick(array.get(zone_max, i) + box_half_points)
            anchor = tick(array.get(zone_anchor, i))
            txt = array.get(zone_text, i)
            col = array.get(zone_color, i)
            txt_col = array.get(zone_text_color, i)
            count = array.get(zone_count, i)
            zone_alpha = count > 1 ? 86 : 91
            line_width = count > 1 ? 2 : 1
            if show_boxes
                array.push(zone_boxes, box.new(left=bar_index - 1000, top=hi, right=bar_index + 25, bottom=lo, xloc=xloc.bar_index, border_color=color.new(col, 35), border_width=1, bgcolor=color.new(col, zone_alpha)))
            array.push(zone_lines, line.new(x1=bar_index - 1000, y1=anchor, x2=bar_index + 25, y2=anchor, xloc=xloc.bar_index, extend=extend.none, color=col, width=line_width, style=count > 1 ? line.style_solid : line.style_dotted))
            array.push(zone_labels, label.new(x=bar_index + 26, y=anchor, text=txt, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(col, 100), textcolor=txt_col, size=size.small, textalign=text.align_left))

if barstate.islast
    f_clear_drawings()
    f_clear_zones()
    f_add_zone(d0cw, "0DTE Γ CW", #15803d)
    f_add_zone(d0pw, "0DTE Γ PW", #b91c1c)
    f_add_zone(d0vt, "0DTE Γ VT", #b45309)
    f_add_zone(d1cw, "1DTE Γ CW", #15803d)
    f_add_zone(d1pw, "1DTE Γ PW", #b91c1c)
    f_add_zone(d1vt, "1DTE Γ VT", #b45309)
    f_add_zone(gp1, "Γ +1", #16a34a)
    f_add_zone(gp2, "Γ +2", #16a34a)
    f_add_zone(gp3, "Γ +3", #16a34a)
    f_add_zone(gp4, "Γ +4", #16a34a)
    f_add_zone(gp5, "Γ +5", #16a34a)
    f_add_zone(gn1, "Γ -1", #dc2626)
    f_add_zone(gn2, "Γ -2", #dc2626)
    f_add_zone(gn3, "Γ -3", #dc2626)
    f_add_zone(gn4, "Γ -4", #dc2626)
    f_add_zone(gn5, "Γ -5", #dc2626)
    f_add_zone(dc1, "Δ +1", #0ea5e9)
    f_add_zone(dc2, "Δ +2", #0ea5e9)
    f_add_zone(dc3, "Δ +3", #0ea5e9)
    f_add_zone(dp1, "Δ -1", #a855f7)
    f_add_zone(dp2, "Δ -2", #a855f7)
    f_add_zone(dp3, "Δ -3", #a855f7)
    f_draw_zones()
