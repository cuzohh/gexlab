{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "desktop:dev": "electron .",
    "desktop:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "plotly.js-dist-min": "^3.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-plotly.js": "^2.6.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.gexlab.desktop",
    "productName": "GexLab v2",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "src/**/*",
      "package.json",
      "next.config.ts"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
